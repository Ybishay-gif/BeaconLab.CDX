PORT=8080
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
BQ_DATASET=planning_app
# Optional analytics dataset override (defaults to BQ_DATASET)
# Use this to read shared analytics views/functions from prod while writing app objects to a separate dataset.
# BQ_ANALYTICS_DATASET=planning_app
ADMIN_ACCESS_CODE=replace-with-strong-random-admin-code
# Optional mutable-table sync helper values for scripts/bq/sync_mutable_tables.ts
# BQ_SYNC_SOURCE_DATASET=planning_app
# BQ_SYNC_TARGET_DATASET=planning_app_dev
# BQ_SYNC_DRY_RUN=true
# Optional raw source table override (backticks required)
# BQ_RAW_CROSS_TACTIC_TABLE=`crblx-beacon-prod.Custom_Reports.Cross Tactic Analysis Full Data `
# Optional if not using default ADC chain
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/service-account.json
