{
  "name": "planning-app-mvp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "check": "tsc --noEmit",
    "test": "GOOGLE_CLOUD_PROJECT=test-project BQ_DATASET=test_dataset ADMIN_ACCESS_CODE=test-code node --import tsx --test $(find src -name \"*.test.ts\" -print)"
  },
  "dependencies": {
